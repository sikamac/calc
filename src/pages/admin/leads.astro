---
// Página de administración de leads — requiere ADMIN_TOKEN para acceder
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />

  <!-- Google Tag Manager -->
  <script>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MHG85P9V');
  </script>
  <!-- End Google Tag Manager -->

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Leads — Calculadora Importaciones</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f4f6f9; color: #1e293b; min-height: 100vh; }

    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-card { background: #fff; border-radius: 12px; padding: 2.5rem; box-shadow: 0 4px 24px rgba(0,0,0,.08); width: 100%; max-width: 360px; }
    .login-card h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: .5rem; }
    .login-card p { color: #64748b; font-size: .9rem; margin-bottom: 1.5rem; }
    .login-card input { width: 100%; padding: .65rem 1rem; border: 1px solid #cbd5e1; border-radius: 8px; font-size: .95rem; margin-bottom: 1rem; outline: none; }
    .login-card input:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.15); }
    .btn { width: 100%; padding: .7rem; background: #2563eb; color: #fff; border: none; border-radius: 8px; font-size: .95rem; font-weight: 600; cursor: pointer; }
    .btn:hover { background: #1d4ed8; }
    .error-msg { color: #dc2626; font-size: .85rem; margin-top: .75rem; display: none; }

    .admin-wrap { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
    .admin-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
    .admin-header h1 { font-size: 1.75rem; font-weight: 700; }
    .admin-header .meta { color: #64748b; font-size: .9rem; margin-top: .2rem; }
    .btn-sm { padding: .45rem 1rem; background: #e2e8f0; color: #475569; border: none; border-radius: 6px; font-size: .85rem; font-weight: 600; cursor: pointer; }
    .btn-sm:hover { background: #cbd5e1; }

    .table-wrap { background: #fff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.06); overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    thead { background: #f8fafc; }
    th { padding: .85rem 1rem; text-align: left; font-weight: 600; color: #475569; white-space: nowrap; border-bottom: 1px solid #e2e8f0; }
    td { padding: .8rem 1rem; border-bottom: 1px solid #f1f5f9; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f8fafc; }
    .lang-badge { display: inline-block; padding: .2rem .55rem; border-radius: 9999px; font-size: .75rem; font-weight: 600; }
    .lang-es { background: #dbeafe; color: #1d4ed8; }
    .lang-en { background: #dcfce7; color: #15803d; }
    .msg-cell { max-width: 220px; }
    .msg-text { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .empty-state { padding: 4rem 2rem; text-align: center; color: #94a3b8; }
    .loading { padding: 4rem 2rem; text-align: center; color: #94a3b8; }
  </style>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MHG85P9V"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <!-- Login -->
  <div class="login-wrap" id="login-section">
    <div class="login-card">
      <h2><span class="brand-name">GIST POINT</span> Calc</h2>
      <p>Ingresá el token de acceso para ver los leads.</p>
      <input type="password" id="token-input" placeholder="Token de acceso" autocomplete="current-password" />
      <button class="btn" id="login-btn">Acceder</button>
      <p class="error-msg" id="login-error">Token incorrecto. Intentá nuevamente.</p>
    </div>
  </div>

  <!-- Leads table -->
  <div class="admin-wrap" id="leads-section" style="display:none">
    <div class="admin-header">
      <div>
        <h1>Leads</h1>
        <p class="meta" id="leads-count">Cargando...</p>
      </div>
      <button class="btn-sm" id="logout-btn">Cerrar sesión</button>
    </div>
    <div class="table-wrap">
      <div class="loading" id="loading-state">Cargando leads...</div>
      <table id="leads-table" style="display:none">
        <thead>
          <tr>
            <th>#</th>
            <th>Fecha</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>Teléfono</th>
            <th>Empresa</th>
            <th>Asunto</th>
            <th>Mensaje</th>
            <th>Idioma</th>
          </tr>
        </thead>
        <tbody id="leads-tbody"></tbody>
      </table>
      <div class="empty-state" id="empty-state" style="display:none">No hay leads registrados todavía.</div>
    </div>
  </div>

  <script is:inline>
    const TOKEN_KEY = 'calc_admin_token';

    const loginSection  = document.getElementById('login-section');
    const leadsSection  = document.getElementById('leads-section');
    const tokenInput    = document.getElementById('token-input');
    const loginBtn      = document.getElementById('login-btn');
    const loginError    = document.getElementById('login-error');
    const logoutBtn     = document.getElementById('logout-btn');
    const leadsCount    = document.getElementById('leads-count');
    const loadingState  = document.getElementById('loading-state');
    const leadsTable    = document.getElementById('leads-table');
    const leadsTbody    = document.getElementById('leads-tbody');
    const emptyState    = document.getElementById('empty-state');

    function formatDate(str) {
      const d = new Date(str + 'Z');
      return d.toLocaleString('es-AR', { dateStyle: 'short', timeStyle: 'short' });
    }

    function escapeHtml(str) {
      if (!str) return '—';
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    async function fetchLeads(token) {
      const res = await fetch('/api/leads', {
        headers: { 'Authorization': 'Bearer ' + token },
      });
      if (res.status === 401) return null;
      return res.json();
    }

    function renderLeads(leads) {
      loadingState.style.display = 'none';
      if (!leads.length) {
        emptyState.style.display = 'block';
        leadsCount.textContent = '0 leads';
        return;
      }
      leadsCount.textContent = leads.length + ' lead' + (leads.length !== 1 ? 's' : '');
      leadsTbody.innerHTML = leads.map(lead => `
        <tr>
          <td>${lead.id}</td>
          <td style="white-space:nowrap">${formatDate(lead.created_at)}</td>
          <td>${escapeHtml(lead.name)}</td>
          <td><a href="mailto:${escapeHtml(lead.email)}" style="color:#2563eb">${escapeHtml(lead.email)}</a></td>
          <td>${escapeHtml(lead.phone)}</td>
          <td>${escapeHtml(lead.company)}</td>
          <td>${escapeHtml(lead.subject)}</td>
          <td class="msg-cell"><span class="msg-text">${escapeHtml(lead.message)}</span></td>
          <td><span class="lang-badge lang-${lead.lang}">${lead.lang}</span></td>
        </tr>
      `).join('');
      leadsTable.style.display = 'table';
    }

    async function showLeads(token) {
      loginSection.style.display  = 'none';
      leadsSection.style.display  = 'block';
      const leads = await fetchLeads(token);
      if (leads === null) {
        sessionStorage.removeItem(TOKEN_KEY);
        loginSection.style.display  = 'flex';
        leadsSection.style.display  = 'none';
        loginError.style.display    = 'block';
        return;
      }
      renderLeads(leads);
    }

    // Auto-login si hay token guardado
    const savedToken = sessionStorage.getItem(TOKEN_KEY);
    if (savedToken) showLeads(savedToken);

    loginBtn.addEventListener('click', async () => {
      const token = tokenInput.value.trim();
      if (!token) return;
      loginError.style.display = 'none';
      loginBtn.textContent = 'Verificando...';
      loginBtn.disabled = true;
      const leads = await fetchLeads(token);
      loginBtn.textContent = 'Acceder';
      loginBtn.disabled = false;
      if (leads === null) {
        loginError.style.display = 'block';
        return;
      }
      sessionStorage.setItem(TOKEN_KEY, token);
      loginSection.style.display = 'none';
      leadsSection.style.display = 'block';
      renderLeads(leads);
    });

    tokenInput.addEventListener('keydown', e => {
      if (e.key === 'Enter') loginBtn.click();
    });

    logoutBtn.addEventListener('click', () => {
      sessionStorage.removeItem(TOKEN_KEY);
      leadsSection.style.display  = 'none';
      loginSection.style.display  = 'flex';
      tokenInput.value = '';
      leadsTbody.innerHTML = '';
      loadingState.style.display = 'block';
      leadsTable.style.display = 'none';
      emptyState.style.display = 'none';
    });
  </script>

</body>
</html>
