---
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/og/calculadora-importaciones.png';
---

<section class="hero-section">
  <div class="hero-wrap">
    <div class="hero-grid">

      <!-- Columna izquierda -->
      <div class="hero-copy">
        <p class="eyebrow">Herramienta gratuita para importar en Argentina</p>
        <h1>Calculá el costo real de importar en Argentina</h1>
        <p class="hero-desc">
          Estimá impuestos, aranceles, flete, seguro y gastos operativos en segundos. Usá la calculadora para decidir con números claros antes de comprar o vender.
        </p>

        <div class="hero-actions">
          <a href="/calculadora" class="btn btn-primary">Usar calculadora</a>
          <a href="/blog" class="btn btn-secondary">Leer guías de importación</a>
        </div>

        <div class="benefit-list">
          <div class="benefit-item">
            <div class="benefit-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <div>
              <p class="benefit-title">Cálculo preciso</p>
              <p>Todos los costos en un solo lugar</p>
            </div>
          </div>
          <div class="benefit-item">
            <div class="benefit-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <div>
              <p class="benefit-title">Datos seguros</p>
              <p>Tu información está protegida</p>
            </div>
          </div>
          <div class="benefit-item">
            <div class="benefit-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <p class="benefit-title">Resultados inmediatos</p>
              <p>Obtené tu estimación al instante</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna derecha — ejemplo estático -->
      <div class="hero-visual" aria-label="Ejemplo visual de estimación de costos">
        <div class="visual-media">
          <Image
            src={heroImage}
            alt="Planificación de costos de importación"
            class="hero-image"
            loading="eager"
            fetchpriority="high"
            format="avif"
            widths={[480, 720, 1200]}
            sizes="(max-width: 640px) calc(100vw - 32px), (max-width: 900px) calc(100vw - 48px), 662px"
            width={1200}
            height={630}
          />
        </div>
        <div class="calc-card">
          <div class="card-head">
            <p class="card-label">Ejemplo de estimación</p>
            <span class="card-pill">Costo aterrizado</span>
          </div>
          <div class="example-rows">
            <div class="example-row">
              <span>Valor EXW</span><a href="/calculadora" class="example-val example-link" aria-label="Ir a la calculadora para editar el Valor EXW">USD 10.000</a>
            </div>
            <div class="example-row">
              <span>Flete y seguro</span><span class="example-val">USD 1.200</span>
            </div>
            <div class="example-row">
              <span>Aranceles</span><span class="example-val">USD 1.320</span>
            </div>
            <div class="example-row">
              <span>Impuestos</span><span class="example-val">USD 2.530</span>
            </div>
            <div class="example-row">
              <span>Gastos operativos</span><span class="example-val">USD 680</span>
            </div>
            <div class="example-row example-subtotal">
              <span>Costo estimado total</span><span>USD 15.730</span>
            </div>
            <div class="example-row example-total">
              <span>Multiplicador sobre EXW</span><span>1,57x</span>
            </div>
          </div>
          <p class="card-disclaimer">Ejemplo ilustrativo: por cada USD 1 de valor EXW, el costo de adquisición estimado sería USD 1,57. Cada operación puede variar.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-section {
    background:
      linear-gradient(115deg, #F7FAFB 0%, #EEF7F7 46%, #F8FAFC 100%);
    padding: 36px 0 56px;
    border-bottom: 1px solid #DDE6F2;
  }

  .hero-wrap {
    width: min(100% - 48px, 1180px);
    margin: 0 auto;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(420px, 1.08fr);
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  .hero-copy {
    padding: 24px 0;
  }

  .eyebrow {
    color: #3084ae;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 18px;
    letter-spacing: 0.03em;
  }
  h1 {
    color: #081C3A;
    font-size: clamp(38px, 5vw, 64px);
    line-height: 1.02;
    letter-spacing: 0;
    margin: 0 0 22px;
    font-weight: 700;
    max-width: 680px;
  }
  .hero-desc {
    color: #5D6B82;
    font-size: 18px;
    line-height: 1.7;
    margin: 0;
    max-width: 620px;
  }
  .hero-actions {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .benefit-list {
    margin-top: 34px;
    display: grid;
    gap: 12px;
  }
  .benefit-item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 14px;
    align-items: center;
    max-width: 520px;
  }
  .benefit-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: #E5F4F4;
    color: #3084ae;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .benefit-title {
    font-size: 15px;
    margin: 0 0 4px;
    color: #081C3A;
    font-weight: 600;
  }
  .benefit-item p {
    font-size: 14px;
    margin: 0;
    color: #5D6B82;
  }

  .hero-visual {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .visual-media {
    position: relative;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
    border-radius: 14px;
    border: 1px solid rgba(6, 44, 79, 0.16);
    box-shadow: 0 26px 60px rgba(8, 28, 58, 0.12);
  }

  .calc-card {
    background: #fff;
    border: 1px solid rgba(6, 44, 79, 0.14);
    border-radius: 14px;
    padding: 24px;
    box-shadow: 0 18px 45px rgba(8, 28, 58, 0.08);
  }

  .card-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    margin-bottom: 18px;
  }

  .card-label {
    font-size: 11px;
    font-weight: 600;
    color: #5D6B82;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  .card-pill {
    color: #246b8c;
    background: #E5F4F4;
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
  }
  .example-rows {
    display: flex;
    flex-direction: column;
  }
  .example-row {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid #F1F5F9;
    font-size: 14px;
    color: #5D6B82;
  }
  .example-val {
    font-weight: 500;
    color: #081C3A;
  }
  .example-link {
    border-radius: 6px;
    text-decoration: none;
    cursor: pointer;
  }
  .example-link:hover,
  .example-link:focus-visible {
    color: #0074D9;
    text-decoration: underline;
  }
  .example-link:focus-visible {
    outline: 2px solid #0074D9;
    outline-offset: 3px;
  }
  .example-subtotal {
    border-bottom: none;
    border-top: 1px solid #DDE6F2;
    margin-top: 4px;
    padding-top: 14px;
    font-weight: 700;
    color: #081C3A;
  }

  .example-subtotal span:last-child {
    color: #081C3A;
  }

  .example-total {
    border-bottom: none;
    border-top: none;
    border-radius: 10px;
    background: #EAF1F4;
    margin-top: 10px;
    padding: 14px 16px;
    font-size: 15px;
    font-weight: 700;
    color: #246b8c;
  }
  .example-total span:last-child {
    color: #246b8c;
    font-size: 22px;
    line-height: 1;
  }
  .card-disclaimer {
    font-size: 12px;
    color: #5D6B82;
    text-align: center;
    margin-top: 12px;
  }

  @media (max-width: 640px) {
    .hero-section {
      padding: 30px 0 44px;
    }

    .hero-wrap {
      width: min(100% - 32px, 1180px);
    }

    .hero-actions .btn {
      width: 100%;
    }

    .card-head {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
